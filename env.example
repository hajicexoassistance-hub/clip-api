# Sumopod API Configuration (Stage 1: Transcription & Analysis)
SUMOPOD_API_KEY=your_sumopod_api_key_here
SUMOPOD_API_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=whisper-1

# Portrait Generator API Configuration
PORTRAITGEN_API_KEY=your_api_key_for_clients_here
PORTRAITGEN_FFMPEG_THREADS=16
PORTRAITGEN_BLUR=true
PORTRAITGEN_USE_GPU=false

# Networking
PORTRAITGEN_BASE_URL=http://localhost:8081/files/
